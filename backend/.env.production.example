# =====================================================================
# TontineSecure — configuration de PRODUCTION (exemple)
# Copier en .env sur le serveur, puis `php artisan key:generate --force`.
# Ne JAMAIS committer le .env réel (secrets).
# =====================================================================

APP_NAME=TontineSecure
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.tontinesecure.example

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

# Journalisation : quotidienne, niveau warning en prod.
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=warning
LOG_DEPRECATIONS_CHANNEL=null

# --- Base de données (service `mysql` du docker-compose) ---
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=tontinesecure
DB_USERNAME=tontinesecure
DB_PASSWORD=change-me-strong-password

# --- Sessions / cache / files d'attente ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
QUEUE_CONNECTION=database
CACHE_STORE=database

# --- Sécurité ---
BCRYPT_ROUNDS=12
# Durée de vie des tokens Sanctum en minutes (7 jours).
SANCTUM_TOKEN_EXPIRATION=10080
# Origines autorisées (front web / EAS), séparées par des virgules.
CORS_ALLOWED_ORIGINS=https://app.tontinesecure.example
# Reverse-proxy de confiance (nginx/load-balancer).
TRUSTED_PROXIES=*

# --- Stockage des documents KYC ---
# `local` = disque privé du conteneur (storage/app/private) ; `s3` pour un bucket dédié.
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- Email (SMTP réel : notifications, rappels) ---
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SCHEME=tls
MAIL_FROM_ADDRESS=no-reply@tontinesecure.example
MAIL_FROM_NAME="${APP_NAME}"

# --- OTP / 2FA ---
# Canal de vérification : `email` (recommandé, GRATUIT via le SMTP ci-dessus),
# `sms` (payant, nécessite un agrégateur), ou `log` (dev).
OTP_CHANNEL=email
# --- SMS (optionnel, si OTP_CHANNEL=sms ou pour alertes) ---
OTP_SMS_DRIVER=log
OTP_SENDER_NAME=TontineSec
# Orange SMS API (Sénégal)
ORANGE_SMS_TOKEN=
ORANGE_SMS_SENDER_URL=
# Twilio
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
