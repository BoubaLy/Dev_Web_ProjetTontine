{
	admin off
	auto_https off
}

# Ecoute sur le port fourni par Railway ($PORT).
:{$PORT:8080} {
	encode gzip

	# API Laravel + sante + Sanctum -> php-fpm (Laravel public/index.php).
	@api path /api/* /up /sanctum/*
	handle @api {
		root * /var/www/html/public
		php_fastcgi 127.0.0.1:9000
	}

	# Tout le reste -> la SPA React (fallback index.html pour le routage client).
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
